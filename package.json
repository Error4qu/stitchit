{
  "name": "stitchit-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "StitchIt - Premium online cloth tailoring platform monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "backend:dev": "cd backend && ./mvnw spring-boot:run",
    "backend:build": "cd backend && ./mvnw clean package"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.0.0"
}
