# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/stitchit
DATABASE_USERNAME=stitchit
DATABASE_PASSWORD=stitchit

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production-min-256-bits

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# SendGrid Configuration
SENDGRID_USERNAME=apikey
SENDGRID_PASSWORD=your-sendgrid-api-key

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Twilio Configuration (for SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Razorpay Configuration
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
