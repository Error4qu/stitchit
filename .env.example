# =============================================================================
# StitchIt - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_DB=stitchit
POSTGRES_USER=stitchit
POSTGRES_PASSWORD=stitchit_secret_change_me
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Apache Kafka
# -----------------------------------------------------------------------------
KAFKA_PORT=9092

# -----------------------------------------------------------------------------
# Spring Boot Backend
# -----------------------------------------------------------------------------
BACKEND_PORT=8080

# JWT Secret (base64 encoded, minimum 256 bits)
# Generate with: openssl rand -base64 64
JWT_SECRET=Y2hhbmdlLXRoaXMtdG8tYS1zZWN1cmUtcmFuZG9tLXN0cmluZy1pbi1wcm9kdWN0aW9uLW1pbi0yNTYtYml0cy1sb25n

# -----------------------------------------------------------------------------
# Google OAuth2
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# CORS Origins (comma-separated)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# -----------------------------------------------------------------------------
# SendGrid (Email)
# -----------------------------------------------------------------------------
SENDGRID_USERNAME=apikey
SENDGRID_PASSWORD=your-sendgrid-api-key

# -----------------------------------------------------------------------------
# Twilio (SMS)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Razorpay (Payments)
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# -----------------------------------------------------------------------------
# Frontend Apps
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id
